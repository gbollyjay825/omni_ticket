OMNI_APP_NAME="Omni Ticket Backend"
OMNI_ENVIRONMENT=local
OMNI_API_PREFIX=/api/v1
OMNI_DATABASE_URL=postgresql+psycopg://omni:omni@localhost:5432/omni_ticket
OMNI_DATABASE_ECHO=false
OMNI_INITIALIZE_DATABASE=true
OMNI_ALLOWED_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]
OMNI_WORKER_INTERVAL_SECONDS=60
OMNI_WORKER_OUTBOUND_LIMIT=50

# Staging/production notes:
# - Set OMNI_ENVIRONMENT=staging or production.
# - Set OMNI_INITIALIZE_DATABASE=false and run `alembic upgrade head` as a release step.
# - Set OMNI_ALLOWED_ORIGINS to the deployed frontend origin(s), never "*".
